---
import { site } from "../data/site";
---

<div class="video-embed">
  <iframe
    src={`https://www.youtube.com/embed/${site.introVideoId}`}
    title="Conocé a Iair, el fundador de TATUX 3D"
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
  ></iframe>
</div>

<style>
  .video-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-blue-glow);
    background: var(--color-blue-deep);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
