---
import { site } from "../data/site";
---

<a
  href={site.introVideoUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="video-slot"
  style={`background-image: linear-gradient(160deg, rgba(0,14,88,0.7) 0%, rgba(3,42,242,0.55) 100%), url('${site.introVideoThumbnail}');`}
  aria-label="Ver a Iair, fundador de TATUX 3D, en YouTube"
>
  <div class="video-slot__play">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
      <path d="M8 5v14l11-7z"></path>
    </svg>
  </div>
  <p class="video-slot__label">Conocé a Iair, el fundador de TATUX 3D</p>
</a>

<style>
  .video-slot {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-xl);
    background-color: var(--color-blue-deep);
    background-size: cover;
    background-position: center;
    text-decoration: none;
    color: var(--color-white-warm);
    overflow: hidden;
    box-shadow: var(--shadow-blue-glow);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .video-slot:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 44px rgba(3, 42, 242, 0.4);
  }

  .video-slot__play {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-white-warm);
    color: var(--color-blue-electric);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s ease;
  }

  .video-slot:hover .video-slot__play {
    transform: scale(1.08);
  }

  .video-slot__label {
    font-weight: 700;
    font-size: 0.95rem;
    padding-inline: 20px;
    text-align: center;
  }
</style>
