<div id="portfolio-modal" class="portfolio-modal" hidden>
  <div class="portfolio-modal__overlay" data-close-portfolio></div>
  <div class="portfolio-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="portfolio-modal-title">
    <button type="button" class="portfolio-modal__close" data-close-portfolio aria-label="Cerrar">&times;</button>
    <h3 id="portfolio-modal-title" class="portfolio-modal__title"></h3>
    <div id="portfolio-modal-grid" class="portfolio-modal__grid"></div>
  </div>
</div>

<script>
  const modal = document.getElementById("portfolio-modal");
  const title = document.getElementById("portfolio-modal-title");
  const grid = document.getElementById("portfolio-modal-grid");
  if (!modal || !title || !grid) throw new Error("#portfolio-modal not found");

  const openModal = (portfolioTitle: string, images: string[]) => {
    title.textContent = portfolioTitle;
    grid.innerHTML = images
      .map((src) => `<div class="portfolio-modal__photo"><img src="${src}" alt="${portfolioTitle}" loading="lazy" /></div>`)
      .join("");
    modal.hidden = false;
    document.body.style.overflow = "hidden";
  };

  const closeModal = () => {
    modal.hidden = true;
    document.body.style.overflow = "";
  };

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;

    const trigger = target.closest("[data-open-portfolio]") as HTMLElement | null;
    if (trigger) {
      event.preventDefault();
      let images: string[] = [];
      try {
        images = JSON.parse(trigger.dataset.portfolioImages || "[]");
      } catch {
        images = [];
      }
      openModal(trigger.dataset.portfolioTitle || "Portfolio", images);
      return;
    }

    if (target.closest("[data-close-portfolio]")) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.hidden) {
      closeModal();
    }
  });
</script>

<style>
  .portfolio-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .portfolio-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 14, 88, 0.6);
    backdrop-filter: blur(2px);
  }

  .portfolio-modal__dialog {
    position: relative;
    width: 100%;
    max-width: 720px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    padding: 32px;
  }

  .portfolio-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: rgba(3, 42, 242, 0.08);
    color: var(--color-blue-deep);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }

  .portfolio-modal__close:hover {
    background: rgba(3, 42, 242, 0.16);
  }

  .portfolio-modal__title {
    font-size: 1.4rem;
    color: var(--color-blue-deep);
    margin: 0 32px 20px 0;
  }

  .portfolio-modal__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .portfolio-modal__photo {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .portfolio-modal__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 600px) {
    .portfolio-modal__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
