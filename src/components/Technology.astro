---
const items = [
  { title: "Multicolor", detail: "Piezas de hasta 4 colores." },
  { title: "Materiales técnicos", detail: "Imprimimos en ABS y Nylon." },
  { title: "Gran escala", detail: "Piezas de hasta 1 metro de altura." },
  { title: "Producción en serie", detail: "Contamos con más de 30 impresoras 3D." },
];
---

<section id="tecnologia" class="section tech aura-mint">
  <div class="container">
    <p class="eyebrow tech__eyebrow">Sin moldes, sin mínimos, sin demoras</p>
    <h2 class="tech__title">La granja que hace posible producir sin límites</h2>
    <div class="tech__grid">
      {
        items.map((item) => (
          <div class="card-soft tech__card">
            <p class="tech__card-title">{item.title}</p>
            <p class="tech__card-detail">{item.detail}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tech__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
  }

  .tech__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    margin-bottom: 40px;
    max-width: 720px;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .tech__card {
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    min-height: 140px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .tech__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .tech__card-title {
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .tech__card-detail {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
