---
const items = [
  { title: "Desarrollo de producto", detail: "Diseño industrial de tu pieza, de la idea a la producción.", image: "/services/desarrollo-producto.jpg" },
  { title: "Producción en serie", detail: "Contamos con más de 30 impresoras 3D.", image: "/services/produccion-serie.jpg" },
  { title: "Impresión Multicolor", detail: "Piezas de hasta 4 colores.", image: "/services/multicolor.jpg" },
  { title: "Materiales técnicos", detail: "Imprimimos en ABS y Nylon.", image: "/services/materiales-tecnicos.jpg" },
  { title: "Impresión a Gran Escala", detail: "Piezas de hasta 1 metro de altura.", image: "/services/gran-escala.jpg" },
];
---

<section id="servicios" class="section tech aura-mint">
  <div class="container">
    <p class="eyebrow tech__eyebrow">Conocé nuestros servicios</p>
    <h2 class="tech__title">La granja que acompaña a más de 100 empresas Argentinas</h2>
    <div class="tech__grid">
      {
        items.map((item) => (
          <div class="card-soft tech__card">
            <div class="tech__card-photo">
              <img src={item.image} alt={item.title} loading="lazy" />
            </div>
            <div class="tech__card-body">
              <p class="tech__card-title">{item.title}</p>
              <p class="tech__card-detail">{item.detail}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="tech__cta">
      <button type="button" class="btn btn-solid" data-open-modal="booking">Iniciar mi producción</button>
    </div>
  </div>
</section>

<style>
  .tech__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
    text-align: center;
  }

  .tech__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    margin-bottom: 40px;
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 20px;
  }

  @media (min-width: 700px) {
    .tech__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1000px) {
    .tech__grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  .tech__card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .tech__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .tech__card-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .tech__card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tech__card-body {
    padding: 20px 24px 28px;
  }

  .tech__card-title {
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .tech__card-detail {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .tech__cta {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }
</style>
