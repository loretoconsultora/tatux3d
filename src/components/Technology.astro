---
const items = [
  { title: "Multicolor", detail: "Piezas de hasta 4 colores." },
  { title: "Materiales técnicos", detail: "Imprimimos en ABS y Nylon." },
  { title: "Gran escala", detail: "Piezas de hasta 1 metro de altura." },
  { title: "Producción en serie", detail: "Contamos con más de 30 impresoras 3D." },
];
---

<section id="servicios" class="section tech aura-mint">
  <div class="container">
    <p class="eyebrow tech__eyebrow">Conocé nuestros servicios</p>
    <h2 class="tech__title">La granja que acompaña a más de 100 empresas Argentinas</h2>
    <div class="tech__grid">
      {
        items.map((item) => (
          <div class="card-soft tech__card">
            <div class="tech__card-photo">
              <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <circle cx="8.5" cy="9.5" r="1.5"></circle>
                <path d="M21 16l-5.5-5.5a2 2 0 0 0-2.8 0L3 20"></path>
              </svg>
            </div>
            <div class="tech__card-body">
              <p class="tech__card-title">{item.title}</p>
              <p class="tech__card-detail">{item.detail}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="tech__cta">
      <button type="button" class="btn btn-solid" data-open-modal="booking">Iniciar mi producción</button>
    </div>
  </div>
</section>

<style>
  .tech__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
    text-align: center;
  }

  .tech__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    margin-bottom: 40px;
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .tech__card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .tech__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .tech__card-photo {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-blue-electric);
    background:
      radial-gradient(circle at 25% 20%, rgba(3, 42, 242, 0.12), transparent 55%),
      radial-gradient(circle at 80% 85%, rgba(64, 255, 159, 0.16), transparent 55%),
      var(--color-bg-soft);
  }

  .tech__card-body {
    padding: 20px 24px 28px;
  }

  .tech__card-title {
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .tech__card-detail {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .tech__cta {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }
</style>
