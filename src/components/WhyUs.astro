---
const items = [
  {
    key: "lideres",
    title: "Líderes en la Industria",
    detail: "Trabajamos con empresas del rubro industrial: piezas, moldes, refacciones, productos terminados y mucho más.",
    images: ["/portfolio/lideres/1.jpg", "/portfolio/lideres/2.jpg"],
  },
  {
    key: "agencias",
    title: "Agencias de Publicidad",
    detail: "Hacemos realidad tu campaña con productos personalizados, a alta velocidad y sin límites de piezas.",
    images: ["/portfolio/agencias/1.jpg", "/portfolio/agencias/2.jpg"],
  },
  {
    key: "arquitectura",
    title: "Arquitectura y Diseño Industrial",
    detail: "Transformá planos en maquetas tangibles listas para presentar — ideal para validar ideas y mostrar tu proyecto a clientes o profesores.",
    images: ["/portfolio/arquitectura/1.jpg", "/portfolio/arquitectura/2.jpg"],
  },
  {
    key: "interiores",
    title: "Diseño de Interiores y Decoración",
    detail: "Lámparas, productos de iluminación, piezas decorativas y muebles, listos para uso personal o para vender toda una línea a catálogo.",
    images: [
      "/portfolio/interiores/1.jpg",
      "/portfolio/interiores/2.jpg",
      "/portfolio/interiores/3.jpg",
      "/portfolio/interiores/4.jpg",
      "/portfolio/interiores/5.jpg",
      "/portfolio/interiores/6.jpg",
      "/portfolio/interiores/7.jpg",
    ],
  },
  {
    key: "merch",
    title: "Merch",
    detail: "El merch que funciona es el que identifica a tu empresa: desde mates hasta llaveros personalizados, con alto sentido de identidad y funcionalidad.",
    images: ["/portfolio/merch/1.jpg"],
  },
];
---

<section id="industrias" class="section why">
  <div class="container">
    <p class="eyebrow why__eyebrow">Transforma tu producción</p>
    <h2 class="why__title">Velocidad. Flexibilidad. Calidad Premium.</h2>
    <p class="why__subtitle">Crecé sin frenos en cualquier industria.</p>

    <div class="why__grid">
      {
        items.map((item) => (
          <button
            type="button"
            class="card-soft why__card"
            data-open-portfolio={item.key}
            data-portfolio-title={item.title}
            data-portfolio-images={JSON.stringify(item.images)}
          >
            <div class="why__card-photo">
              <img src={item.images[0]} alt={item.title} loading="lazy" />
            </div>
            <div class="why__card-body">
              <p class="why__card-title">{item.title}</p>
              <p class="why__card-detail">{item.detail}</p>
              <p class="why__card-link">Ver portfolio →</p>
            </div>
          </button>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why {
    background: var(--color-bg);
  }

  .why__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
    text-align: center;
  }

  .why__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .why__subtitle {
    color: var(--color-text-muted);
    max-width: 620px;
    margin-top: 12px;
    margin-bottom: 40px;
    margin-inline: auto;
    text-align: center;
  }

  .why__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 20px;
  }

  .why__card {
    display: block;
    width: 100%;
    border: none;
    background: none;
    font: inherit;
    color: inherit;
    cursor: pointer;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .why__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .why__card-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .why__card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .why__card-body {
    padding: 20px 24px 28px;
  }

  .why__card-title {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .why__card-detail {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .why__card-link {
    color: var(--color-blue-electric);
    font-size: 0.85rem;
    font-weight: 700;
    margin-top: 12px;
  }

  @media (min-width: 700px) {
    .why__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
