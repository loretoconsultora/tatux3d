---
import { site } from "../data/site";
import VideoSlot from "./VideoSlot.astro";
---

<section id="llamada" class="section booking-benefits aura-mint">
  <div class="container booking-benefits__inner">
    <h2 class="booking-benefits__title">¿Por qué agendar tu Llamada?</h2>

    <div class="booking-benefits__grid">
      <ul class="booking-benefits__list">
        <li class="card-soft"><strong>Vas a descubrir</strong> dónde estás perdiendo tiempo o plata en tu proceso actual.</li>
        <li class="card-soft"><strong>Vas a recibir</strong> una recomendación concreta de materiales, escala y tiempos — pensada por un diseñador industrial, no solo por un operador de impresoras.</li>
        <li class="card-soft"><strong>Vas a salir</strong> con el siguiente paso claro, sin ningún compromiso de compra.</li>
      </ul>

      <div class="booking-benefits__video">
        <VideoSlot videoId={site.bookingVideoId} title="Por qué agendar tu Llamada con TATUX 3D" aspectRatio="9/16" />
      </div>
    </div>

    <button type="button" class="btn btn-solid" data-open-modal="booking">Agendar Llamada de Cotización</button>
  </div>
</section>

<style>
  .booking-benefits__inner {
    max-width: 980px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .booking-benefits__title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--color-blue-deep);
  }

  .booking-benefits__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 24px;
    width: 100%;
    align-items: center;
    text-align: left;
  }

  .booking-benefits__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }

  .booking-benefits__list li {
    border-radius: 14px;
    padding: 14px 18px;
    font-size: 0.92rem;
    color: var(--color-text);
  }

  .booking-benefits__list strong {
    color: var(--color-blue-electric);
  }

  .booking-benefits__video {
    min-width: 0;
    width: 100%;
    max-width: 300px;
    margin-inline: auto;
  }

  @media (min-width: 800px) {
    .booking-benefits__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 36px;
    }
  }
</style>
