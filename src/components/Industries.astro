---
const items = [
  { title: "Líderes en la Industria", detail: "Elimina el costo de moldes y reduce la necesidad de stock." },
  { title: "Agencias de Publicidad", detail: "Piezas para campañas, a escala y a tiempo, sin perder identidad de marca." },
  { title: "Arquitectura y Diseño", detail: "Transformá planos en maquetas tangibles listas para presentar." },
  { title: "Interiorismo", detail: "Objetos y piezas decorativas a medida, tal como los imaginás." },
  { title: "Profesionales de la Salud", detail: "Modelos precisos y a medida para tratamientos más efectivos." },
  { title: "Merch", detail: "Piezas de marca en volumen, con la misma calidad en la unidad 1 y en la 1.000." },
];
---

<section id="industrias" class="section industries">
  <div class="container">
    <p class="eyebrow industries__eyebrow">Elegidos por líderes de cada rubro en toda Argentina</p>
    <h2 class="industries__title">Producción 3D para tu industria</h2>
    <div class="industries__grid">
      {
        items.map((item) => (
          <div class="card-soft industries__card">
            <div class="industries__card-photo">
              <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <circle cx="8.5" cy="9.5" r="1.5"></circle>
                <path d="M21 16l-5.5-5.5a2 2 0 0 0-2.8 0L3 20"></path>
              </svg>
            </div>
            <div class="industries__card-body">
              <p class="industries__card-title">{item.title}</p>
              <p class="industries__card-detail">{item.detail}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .industries {
    background: var(--color-bg-soft);
  }

  .industries__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
  }

  .industries__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    margin-bottom: 40px;
    max-width: 720px;
  }

  .industries__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }

  .industries__card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .industries__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .industries__card-photo {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-blue-electric);
    background:
      radial-gradient(circle at 25% 20%, rgba(3, 42, 242, 0.12), transparent 55%),
      radial-gradient(circle at 80% 85%, rgba(64, 255, 159, 0.16), transparent 55%),
      var(--color-bg-soft);
  }

  .industries__card-body {
    padding: 20px 24px 28px;
  }

  .industries__card-title {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .industries__card-detail {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
