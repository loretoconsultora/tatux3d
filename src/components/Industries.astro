---
const items = [
  { title: "Iluminación & Diseño", detail: "Cada pantalla y cada forma, tal como la imaginás — sin producir en masa." },
  { title: "Merchandising Empresarial", detail: "Piezas de marca en volumen, con la misma calidad en la unidad 1 y en la 1.000." },
  { title: "Agencias & BTL", detail: "Piezas para campañas, a escala y a tiempo, sin perder identidad de marca." },
  { title: "Talleres & Manufactura", detail: "Elimina el costo de moldes y reduce la necesidad de stock." },
  { title: "Arquitectura", detail: "Transformá planos en maquetas tangibles listas para presentar." },
  { title: "Salud & Odontología", detail: "Modelos precisos y a medida para tratamientos más efectivos." },
  { title: "Repuestos", detail: "Devuelve vida a piezas que ya no se consiguen." },
  { title: "Prototipos", detail: "De la idea a la mano en horas." },
];
---

<section id="industrias" class="section industries">
  <div class="container">
    <p class="eyebrow industries__eyebrow">Del diseño a la pieza, sea cual sea tu rubro</p>
    <h2 class="industries__title">Producción 3D para tu industria</h2>
    <div class="industries__grid">
      {
        items.map((item) => (
          <div class="card-soft industries__card">
            <p class="industries__card-title">{item.title}</p>
            <p class="industries__card-detail">{item.detail}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .industries {
    background: var(--color-bg-soft);
  }

  .industries__eyebrow {
    color: var(--color-blue-electric);
    margin-bottom: 8px;
  }

  .industries__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
    margin-bottom: 40px;
    max-width: 720px;
  }

  .industries__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }

  .industries__card {
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .industries__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .industries__card-title {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 8px;
    color: var(--color-blue-deep);
  }

  .industries__card-detail {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
