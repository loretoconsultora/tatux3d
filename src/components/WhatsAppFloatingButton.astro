---
import { site } from "../data/site";

const href = `${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<div class="whatsapp-widget">
  <div id="whatsapp-bubble" class="whatsapp-bubble" hidden>
    <div class="whatsapp-bubble__header">
      <div class="whatsapp-bubble__title">
        <span class="whatsapp-bubble__avatar">T</span>
        <div>
          <p class="whatsapp-bubble__name">TATUX 3D</p>
          <p class="whatsapp-bubble__status">Normalmente responde en el día</p>
        </div>
      </div>
      <button type="button" class="whatsapp-bubble__close" data-close-whatsapp aria-label="Cerrar">&times;</button>
    </div>

    <p class="whatsapp-bubble__message">
      ¡Hola! 👋 Contanos tu proyecto y te ayudamos a encontrar la mejor forma de producirlo — sin costo y sin
      compromiso.
    </p>

    <a href={href} target="_blank" rel="noopener noreferrer" class="whatsapp-bubble__cta">
      <svg viewBox="0 0 32 32" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path
          d="M16.02 3C9.4 3 4 8.4 4 15.02c0 2.23.62 4.38 1.78 6.26L3 29l7.9-2.7a12.9 12.9 0 0 0 5.12 1.05h.01c6.62 0 12.02-5.4 12.02-12.02C28.05 8.4 22.65 3 16.02 3zm0 21.9h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-4.7 1.6 1.58-4.58-.24-.38a9.86 9.86 0 0 1-1.51-5.25c0-5.46 4.45-9.91 9.9-9.91 2.65 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c0 5.46-4.45 9.91-9.6 9.91zm5.43-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.5-.17 0-.37-.02-.57-.02s-.52.07-.8.37c-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.09 4.49.71.31 1.27.49 1.7.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"
        ></path>
      </svg>
      Hablar por WhatsApp
    </a>
  </div>

  <button type="button" id="whatsapp-toggle" class="whatsapp-fab" aria-label="Hablar por WhatsApp" aria-expanded="false">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true">
      <path
        d="M16.02 3C9.4 3 4 8.4 4 15.02c0 2.23.62 4.38 1.78 6.26L3 29l7.9-2.7a12.9 12.9 0 0 0 5.12 1.05h.01c6.62 0 12.02-5.4 12.02-12.02C28.05 8.4 22.65 3 16.02 3zm0 21.9h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-4.7 1.6 1.58-4.58-.24-.38a9.86 9.86 0 0 1-1.51-5.25c0-5.46 4.45-9.91 9.9-9.91 2.65 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c0 5.46-4.45 9.91-9.6 9.91zm5.43-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.5-.17 0-.37-.02-.57-.02s-.52.07-.8.37c-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.09 4.49.71.31 1.27.49 1.7.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"
      ></path>
    </svg>
  </button>
</div>

<script>
  const toggle = document.getElementById("whatsapp-toggle");
  const bubble = document.getElementById("whatsapp-bubble");
  if (!toggle || !bubble) throw new Error("WhatsApp widget elements not found");

  const closeBubble = () => {
    bubble.hidden = true;
    toggle.setAttribute("aria-expanded", "false");
  };

  const openBubble = () => {
    bubble.hidden = false;
    toggle.setAttribute("aria-expanded", "true");
  };

  toggle.addEventListener("click", () => {
    if (bubble.hidden) openBubble();
    else closeBubble();
  });

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    if (target.closest("[data-close-whatsapp]")) {
      closeBubble();
      return;
    }
    const isOutside = !bubble.contains(target) && !toggle.contains(target);
    if (isOutside && !bubble.hidden) closeBubble();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !bubble.hidden) closeBubble();
  });
</script>

<style>
  .whatsapp-widget {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
  }

  .whatsapp-fab {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    transition: transform 0.15s ease;
    cursor: pointer;
    flex-shrink: 0;
  }

  .whatsapp-fab:hover {
    transform: translateY(-2px) scale(1.05);
  }

  .whatsapp-bubble {
    width: min(310px, calc(100vw - 40px));
    background: #ffffff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 18px;
    animation: whatsapp-pop 0.18s ease;
  }

  @keyframes whatsapp-pop {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .whatsapp-bubble__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
  }

  .whatsapp-bubble__title {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .whatsapp-bubble__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-blue-electric);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  .whatsapp-bubble__name {
    font-weight: 700;
    color: var(--color-blue-deep);
    font-size: 0.95rem;
  }

  .whatsapp-bubble__status {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .whatsapp-bubble__close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    padding: 2px;
  }

  .whatsapp-bubble__message {
    background: var(--color-bg-soft);
    border-radius: 14px;
    padding: 12px 14px;
    font-size: 0.88rem;
    color: var(--color-text);
    margin-bottom: 14px;
  }

  .whatsapp-bubble__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    padding: 12px 16px;
    border-radius: var(--radius-full);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .whatsapp-bubble__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.4);
  }
</style>
