---
import BookingFormCard from "./BookingFormCard.astro";
---

<div id="booking-modal" class="booking-modal" hidden>
  <div class="booking-modal__overlay" data-close-modal></div>
  <div class="booking-modal__dialog" role="dialog" aria-modal="true" aria-label="Agendar Llamada">
    <button type="button" class="booking-modal__close" data-close-modal aria-label="Cerrar">&times;</button>
    <BookingFormCard formId="modal-booking" heading="Producción en tiempo récord" />
  </div>
</div>

<script>
  const modal = document.getElementById("booking-modal");
  if (!modal) throw new Error("#booking-modal not found");

  const openModal = () => {
    modal.hidden = false;
    document.body.style.overflow = "hidden";
  };

  const closeModal = () => {
    modal.hidden = true;
    document.body.style.overflow = "";
  };

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;

    if (target.closest("[data-open-modal='booking']")) {
      event.preventDefault();
      openModal();
      return;
    }

    if (target.closest("[data-close-modal]")) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.hidden) {
      closeModal();
    }
  });

  // Auto-open once per browser session, 3s after the page loads, unless the
  // visitor already opened or dismissed it.
  const AUTO_OPEN_KEY = "tatux-welcome-modal-shown";
  if (!sessionStorage.getItem(AUTO_OPEN_KEY)) {
    setTimeout(() => {
      if (modal.hidden) openModal();
      sessionStorage.setItem(AUTO_OPEN_KEY, "1");
    }, 3000);
  }
</script>

<style>
  .booking-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .booking-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 14, 88, 0.6);
    backdrop-filter: blur(2px);
  }

  .booking-modal__dialog {
    position: relative;
    width: 100%;
    max-width: 440px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: var(--radius-lg);
  }

  .booking-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: rgba(3, 42, 242, 0.08);
    color: var(--color-blue-deep);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }

  .booking-modal__close:hover {
    background: rgba(3, 42, 242, 0.16);
  }
</style>
