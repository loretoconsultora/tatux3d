---
import { site } from "../data/site";
---

<footer class="footer aura-blue">
  <div class="container footer__inner">
    <p class="eyebrow footer__eyebrow">Cupos limitados · Respuesta en menos de 24 horas</p>
    <h2 class="footer__title">Agendá tu {site.appointmentName}</h2>
    <p class="footer__subtitle">Escribinos y te ayudamos a encontrar la mejor forma de producir.</p>
    <button type="button" class="btn btn-solid" data-open-modal="booking">Quiero mi diagnóstico gratis</button>

    <p class="footer__copyright">© {new Date().getFullYear()} TATUX 3D - Todos los derechos reservados.</p>

    <div class="footer__social">
      <a href={site.social.facebook} aria-label="Facebook">FB</a>
      <a href={site.social.instagram} aria-label="Instagram">IG</a>
      <a href={site.social.linkedin} aria-label="LinkedIn">IN</a>
      <a href={`mailto:${site.email}`} aria-label="Email">@</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: 88px;
  }

  .footer__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .footer__eyebrow {
    color: var(--color-blue-electric);
  }

  .footer__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    color: var(--color-blue-deep);
  }

  .footer__subtitle {
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .footer__copyright {
    margin-top: 48px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer__social {
    display: flex;
    gap: 16px;
  }

  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(3, 42, 242, 0.08);
    color: var(--color-blue-electric);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.8rem;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .footer__social a:hover {
    background: rgba(3, 42, 242, 0.16);
    transform: translateY(-2px);
  }
</style>
