---
import { site } from "../data/site";
import VideoSlot from "./VideoSlot.astro";
import BookingFormCard from "./BookingFormCard.astro";

const whatsappHref = `${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<section id="top" class="hero aura-blue-mint">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="hero__badge">Aliados en producción, no proveedores</p>
      <h1 class="hero__title">De la idea a la pieza. <span>Sin moldes, sin mínimos, sin demoras.</span></h1>
      <p class="hero__subtitle">
        Somos tu aliado en producción 3D: co-diseñamos tu proyecto, ajustamos el volumen bajo demanda y te damos la
        velocidad, flexibilidad y control para que tu negocio crezca sin límites de producción.
      </p>

      <div class="hero__ctas">
        <button type="button" class="btn btn-solid hero__cta" data-open-modal="booking">Quiero mi diagnóstico gratis</button>
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn btn-outline hero__whatsapp">
          <svg viewBox="0 0 32 32" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path
              d="M16.02 3C9.4 3 4 8.4 4 15.02c0 2.23.62 4.38 1.78 6.26L3 29l7.9-2.7a12.9 12.9 0 0 0 5.12 1.05h.01c6.62 0 12.02-5.4 12.02-12.02C28.05 8.4 22.65 3 16.02 3zm0 21.9h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-4.7 1.6 1.58-4.58-.24-.38a9.86 9.86 0 0 1-1.51-5.25c0-5.46 4.45-9.91 9.9-9.91 2.65 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c0 5.46-4.45 9.91-9.6 9.91zm5.43-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.5-.17 0-.37-.02-.57-.02s-.52.07-.8.37c-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.09 4.49.71.31 1.27.49 1.7.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35z"
            ></path>
          </svg>
          Hablá por WhatsApp con un asesor
        </a>
      </div>

      <p class="hero__proof">
        Elegidos por líderes industriales, arquitectos, agencias de marketing y profesionales de la salud de toda
        Argentina.
      </p>
    </div>

    <div class="hero__panel">
      <VideoSlot />
      <BookingFormCard formId="hero-booking" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: 72px;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  .hero__badge {
    display: inline-block;
    background: rgba(3, 42, 242, 0.08);
    border: 1px solid rgba(3, 42, 242, 0.16);
    border-radius: var(--radius-full);
    padding: 8px 18px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-blue-electric);
  }

  .hero__title {
    font-size: clamp(1.9rem, 3.6vw, 2.75rem);
    line-height: 1.15;
    text-align: left;
    color: var(--color-blue-deep);
  }

  .hero__title span {
    color: var(--color-blue-electric);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 560px;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 8px;
  }

  .hero__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .hero__proof {
    margin-top: 12px;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text-muted);
    max-width: 480px;
  }

  .hero__panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 56px;
    }
  }
</style>
